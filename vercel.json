{
  "regions": [
    "sin1"
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 10
    },
    "app/api/cron/agent-autopilot/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/class-reminders/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/today-reminders/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/class-reminders",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/db-backup",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/agent-autopilot",
      "schedule": "*/15 * * * *"
    }
  ]
}