{
  "expo": {
    "name": "Gravity Stretching",
    "slug": "gravity-stretching",
    "scheme": "gravitystretching",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2C6E49"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookgravity.gravitystretching",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Gravity Stretching uses the camera to scan client check-in QR codes at the studio.",
        "NSUserNotificationsUsageDescription": "Gravity Stretching sends reminders before your class and notifies trainers of new bookings."
      },
      "associatedDomains": ["applinks:bookgravity.com", "applinks:canggu.bookgravity.com", "applinks:ubud.bookgravity.com"]
    },
    "android": {
      "package": "com.bookgravity.gravitystretching",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2C6E49"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-camera", {
        "cameraPermission": "Allow Gravity Stretching to access the camera for QR check-in."
      }],
      ["expo-notifications", {
        "icon": "./assets/notification-icon.png",
        "color": "#2C6E49"
      }],
      ["expo-splash-screen", {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#2C6E49"
      }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://bookgravity.com",
      "eas": {
        "projectId": "PLACEHOLDER_UNTIL_EAS_INIT"
      }
    },
    "owner": "PLACEHOLDER_EXPO_USERNAME"
  }
}
