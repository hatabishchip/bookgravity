{
  "expo": {
    "name": "Gravity Stretching",
    "slug": "gravity-stretching",
    "scheme": "gravitystretching",
    "platforms": ["ios", "android"],
    "version": "1.0.7",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/538cbb55-1fe3-4195-bed2-b8ece8b0f43d",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookgravity.gravitystretching",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Gravity Stretching uses the camera to scan client check-in QR codes at the studio.",
        "NSUserNotificationsUsageDescription": "Gravity Stretching sends reminders before your class and notifies trainers of new bookings."
      },
      "associatedDomains": [
        "applinks:bookgravity.com",
        "applinks:canggu.bookgravity.com",
        "applinks:ubud.bookgravity.com"
      ]
    },
    "android": {
      "package": "com.bookgravity.gravitystretching",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35,
            "compileSdkVersion": 35
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Gravity Stretching to access the camera for QR check-in."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2C6E49"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-asset",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://bookgravity.com",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "538cbb55-1fe3-4195-bed2-b8ece8b0f43d"
      }
    },
    "owner": "hatabishchip"
  }
}
