generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Studio {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  isDefault     Boolean  @default(false)
  logoUrl       String?
  faviconUrl    String?
  // Main-service prices (per person) — used as defaults when creating slots
  groupPrice    Float    @default(300000)
  kidsPrice     Float    @default(200000)
  privatePrice  Float    @default(800000)
  // WhatsApp Cloud API integration: gated per-studio. New studios start
  // disabled; the super-admin flips this to `true` only after the studio's
  // WhatsApp Business Account has been connected (creds below populated).
  // While false, the FloatingInbox FAB / /admin/inbox / /trainer/inbox
  // pages stay hidden and the inbox API rejects requests for this studio.
  whatsappEnabled Boolean @default(false)
  // Per-studio WhatsApp Cloud API credentials. Populated by /super-admin
  // either via Embedded Signup OAuth (future) or manual entry from Meta
  // Business Suite. If null we fall back to the global env vars so the
  // existing Canggu deployment keeps working unchanged.
  whatsappPhoneNumberId      String?
  whatsappAccessToken        String?
  whatsappBusinessAccountId  String?
  whatsappDisplayPhone       String?
  whatsappConnectedAt        DateTime?
  // ISO 639-1 code (e.g. "ru", "en", "id"). When set, inbound WhatsApp
  // messages get auto-translated to this language for display in the
  // inbox; outbound replies typed in this language get auto-translated
  // to the client's detected language before delivery. Null = off.
  inboxLanguage              String?
  createdAt     DateTime @default(now())

  users        User[]
  trainers     Trainer[]
  timeSlots    TimeSlot[]
  blockedDays  BlockedDay[]
  payments     TrainerPayment[]
  expenses     Expense[]
  services     AdditionalService[]
  whatsappConversations WhatsAppConversation[]
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  role                String               @default("TRAINER")
  studioId            String
  studio              Studio               @relation(fields: [studioId], references: [id])
  trainer             Trainer?
  passwordResetTokens PasswordResetToken[]
  pushTokens          NativePushToken[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

// Expo push tokens registered by the mobile app for a logged-in user.
// One row per device — a user with iPhone + iPad would have two. The
// platform / deviceName fields help debugging delivery later; expoPushToken
// is what we send through the Expo Push API.
model NativePushToken {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expoPushToken String   @unique
  platform      String
  deviceName    String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Trainer {
  id             String           @id @default(cuid())
  name           String
  whatsapp       String           @default("")
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id])
  studioId       String
  studio         Studio           @relation(fields: [studioId], references: [id])
  timeSlots      TimeSlot[]
  assistedSlots  TimeSlot[]       @relation("SlotAssistant")
  commissionRate Int              @default(20)
  color          String           @default("#6366F1")
  payments       TrainerPayment[]
  assignedConversations WhatsAppConversation[] @relation("ConversationAssignedTrainer")
  conversationAccess    WhatsAppConversationAccess[] @relation("TrainerConversationAccess")
  sentMessages          WhatsAppMessage[]      @relation("MessageFromTrainer")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model BlockedDay {
  id        String   @id @default(cuid())
  date      String
  reason    String?
  studioId  String
  studio    Studio   @relation(fields: [studioId], references: [id])
  createdAt DateTime @default(now())

  @@unique([studioId, date])
}

model TrainerPayment {
  id        String   @id @default(cuid())
  trainerId String
  trainer   Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  studioId  String
  studio    Studio   @relation(fields: [studioId], references: [id])
  amount    Float
  month     String
  note      String?
  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  category    String
  description String?
  date        String
  studioId    String
  studio      Studio   @relation(fields: [studioId], references: [id])
  createdAt   DateTime @default(now())
}

model TimeSlot {
  id          String    @id @default(cuid())
  date        String
  startTime   String
  endTime     String
  trainerId   String?
  trainer     Trainer?  @relation(fields: [trainerId], references: [id])
  assistantId String?
  assistant   Trainer?  @relation("SlotAssistant", fields: [assistantId], references: [id])
  classType     String  @default("GROUP") // GROUP | KIDS | PRIVATE
  publicVisible Boolean @default(true)
  maxCapacity Int       @default(6)
  price       Float     @default(0)
  studioId    String
  studio      Studio    @relation(fields: [studioId], references: [id])
  bookings    Booking[]
  // Slots created together as a weekly recurrence share the same seriesId.
  // Null = standalone, one-off slot. Used by the schedule modal to offer
  // "Repeat weekly" and to "stop series" on a specific future occurrence.
  seriesId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([seriesId])
}

model Booking {
  id             String           @id @default(cuid())
  slotId         String
  slot           TimeSlot         @relation(fields: [slotId], references: [id])
  clientName     String
  clientEmail    String
  clientPhone    String
  clientTelegram String?
  status         String           @default("CONFIRMED")
  paymentType    String           @default("PENDING")
  paymentStatus  String           @default("UNPAID")
  ticketCode     String           @default("")
  checkedIn      Boolean          @default(false)
  notes          String?
  services       BookingService[]
  // Diagnostic fields for the trainer's WhatsApp notification — populated by
  // the booking POST handler so we can audit why a trainer didn't get pinged
  // even though the message was "accepted" by Meta. Values:
  //   sent       — Meta accepted the message (template / free-form text)
  //   failed     — Meta rejected it; reason in waNotifyTrainerError
  //   skipped    — Trainer has no whatsapp number set
  //   not_sent   — Default; row hasn't been processed yet
  waNotifyTrainerStatus    String?  @default("not_sent")
  waNotifyTrainerError     String?
  waNotifyTrainerMessageId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model AdditionalService {
  id       String           @id @default(cuid())
  name     String
  price    Float
  active   Boolean          @default(true)
  studioId String
  studio   Studio           @relation(fields: [studioId], references: [id])
  bookings BookingService[]
}

model BookingService {
  id        String            @id @default(cuid())
  bookingId String
  booking   Booking           @relation(fields: [bookingId], references: [id])
  serviceId String
  service   AdditionalService @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
}

// ---------------------------------------------------------------------------
// WhatsApp inbox
//
// One Conversation per (studio, clientPhone). The "assignedTrainer" determines
// which trainer can see the chat in /trainer/inbox; null means admin-only
// (e.g. when a stranger writes to the business number before any booking).
//
// Assignment is updated by /api/bookings when a client books a slot: the new
// booking's trainer takes over the conversation.
//
// 24-hour rule (Meta): we can send free-form messages only when
// lastInboundAt is within the past 24h. Outside that window only approved
// templates work. We store lastInboundAt to render that UI affordance.
// ---------------------------------------------------------------------------
model WhatsAppConversation {
  id                String   @id @default(cuid())
  studioId          String
  studio            Studio   @relation(fields: [studioId], references: [id])
  clientPhone       String   // normalized to digits only, no leading +
  clientName        String?  // best-known name (latest booking or WhatsApp profile)
  // ISO 639-1 code detected from this client's inbound messages (e.g. "en",
  // "es", "ru"). Used as the target language when admin replies and the
  // studio has inboxLanguage set. Updated as fresher inbounds come in.
  clientLanguage    String?
  // assignedTrainerId — kept as the "primary / most-recent trainer" for sort
  // & display (chip in admin list). Actual access control is via the
  // WhatsAppConversationAccess join table below, which lets multiple
  // trainers see the same chat when a client booked with each of them.
  assignedTrainerId String?
  assignedTrainer   Trainer? @relation("ConversationAssignedTrainer", fields: [assignedTrainerId], references: [id])
  access            WhatsAppConversationAccess[]
  lastMessageAt     DateTime @default(now())
  lastInboundAt     DateTime?
  // Unread counters tracked separately per role so admin & trainer don't
  // clobber each other when one of them reads.
  unreadAdmin       Int      @default(0)
  unreadTrainer     Int      @default(0)
  messages          WhatsAppMessage[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studioId, clientPhone])
  @@index([studioId, lastMessageAt])
  @@index([assignedTrainerId])
}

// Join table for "this trainer can see this conversation". One row per
// (conversation, trainer). Populated by the booking flow when a client books
// a slot — the slot's trainer gets a row here (idempotent), so multiple
// trainers can share access to a chat when the same client books with each.
model WhatsAppConversationAccess {
  id             String   @id @default(cuid())
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  trainerId      String
  trainer        Trainer  @relation("TrainerConversationAccess", fields: [trainerId], references: [id])
  grantedAt      DateTime @default(now())

  @@unique([conversationId, trainerId])
  @@index([trainerId])
}

model WhatsAppMessage {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction       String   // "INBOUND" | "OUTBOUND"
  type            String   // "text" | "image" | "audio" | "video" | "document" | "sticker" | "template" | "system"
  body            String?  // text body — sender's ORIGINAL words (inbound)
                           // OR admin's typed text (outbound, before translation)
  // Auto-translation: when studio.inboxLanguage is set we render bubbles using
  // translatedBody (falling back to body when no translation was needed/done).
  // For inbound: client wrote in `body` (their language), translatedBody is
  // the admin-facing translation.
  // For outbound: admin typed in `body` (studio's inboxLanguage),
  // translatedBody is what we actually sent to the client.
  translatedBody  String?
  // ISO 639-1 of `body` (detected once at persist time).
  detectedLang    String?
  mediaUrl        String?  // we don't download media yet; store Meta media_id here for later fetching
  mediaMime       String?
  templateName    String?  // for outbound type=template
  waMessageId     String?  @unique // Meta's wamid.* for status correlation
  status          String   @default("queued") // queued | sent | delivered | read | failed
  errorDetail     String?
  fromTrainerId   String?  // OUTBOUND only: which trainer sent it (null = admin or system/booking-confirmation)
  fromTrainer     Trainer? @relation("MessageFromTrainer", fields: [fromTrainerId], references: [id])
  // Marker for messages imported from a previous WhatsApp export (one-time migration).
  importedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([waMessageId])
}
