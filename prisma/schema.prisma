generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Studio {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  // ISO 3166-1 alpha-2 country code (e.g. "ID", "KZ"). Groups studios by
  // country on the public chooser so a visitor on Bali never sees Almaty.
  country       String?
  // IANA timezone (e.g. "Asia/Makassar"). Null = Bali default. Plumbed via
  // lib/tz.studioDateStr for the day a studio opens outside WITA.
  timezone      String?
  // City the studio is in (e.g. "Canggu", "Almaty"). The public label is just
  // the city — the "Gravity Stretching" prefix is implicit branding.
  city          String?
  isDefault     Boolean  @default(false)
  // Super-admin "eye" toggle. When false the studio is hidden from the public
  // chooser + the booking-page studio switcher, but the booking page itself is
  // still reachable directly at /<slug> (so the admin can open it from their
  // dashboard before going public). Default true = visible to clients.
  publicVisible Boolean  @default(true)
  logoUrl       String?
  faviconUrl    String?
  // Cover photo shown on the studio chooser (apex) and as a faint backdrop on
  // the booking calendar. Stored as a data URL (like logoUrl). Null falls back
  // to the bundled /public/studios/<slug>.jpg.
  coverUrl      String?
  // Google Maps (or any) link to the studio's physical location. Shown in the
  // client's WhatsApp booking confirmation so they can navigate to the studio.
  locationUrl   String?
  // Admin's WhatsApp number to receive a copy of every booking alert (in
  // addition to the assigned trainer). Empty = admin copy off.
  bookingAlertWhatsapp String?
  // ISO 4217 currency for this studio's prices (e.g. "IDR", "USD"). Drives
  // booking-widget money formatting. Defaults to IDR so existing studios are
  // unaffected; the USA / Online studio uses "USD".
  currency      String   @default("IDR")
  // Main-service prices (per person) — used as defaults when creating slots
  groupPrice    Float    @default(300000)
  kidsPrice     Float    @default(200000)
  privatePrice  Float    @default(800000)
  // Membership price PER CLASS (a pass of N classes costs membershipClassPrice
  // x N). Cheaper than the drop-in groupPrice, so clients save by buying a pass.
  membershipClassPrice Float @default(250000)
  // Discounted single-class price for an Indonesian local resident. Only offered
  // in Indonesian studios (country == "ID"); a trainer ticks "Local" at payment.
  localPrice    Float    @default(200000)
  // WhatsApp Cloud API integration: gated per-studio. New studios start
  // disabled; the super-admin flips this to `true` only after the studio's
  // WhatsApp Business Account has been connected (creds below populated).
  // While false, the FloatingInbox FAB / /admin/inbox / /trainer/inbox
  // pages stay hidden and the inbox API rejects requests for this studio.
  whatsappEnabled Boolean @default(false)
  // Auto-assign incoming WhatsApp leads (a first message from an unknown number
  // with no booking) to trainers in a round-robin. Off by default; the admin UI
  // disables the toggle while whatsappEnabled is false. The rotation pool is the
  // trainers with inLeadRotation=true; leadRotationLastTrainerId is the cursor
  // (who got the previous lead) so the next lead goes to the following trainer.
  autoAssignLeads        Boolean @default(false)
  leadRotationLastTrainerId String?
  // When WhatsApp is enabled, require clients to confirm a public booking with
  // a one-time code sent to their WhatsApp (anti-spam). On by default; admins
  // can turn it off per studio in Settings. Ignored when WhatsApp is disabled.
  requireBookingOtp Boolean @default(true)
  // "Booking Confirmation" section, Email channel toggle (on by default).
  // When WhatsApp is active the client is confirmed via WhatsApp, so this email
  // goes ONLY to the studio admin (full booking info). When WhatsApp is not
  // active, the email goes to the client AND the admin. Off = no booking email.
  confirmEmail Boolean @default(true)
  // Notifications panel — per-role, per-channel toggles (all on by default).
  // CLIENT:
  emailClientBooking  Boolean @default(true)  // booking confirmation email to the client
  remindTomorrow      Boolean @default(true)  // WhatsApp "class is tomorrow" reminder
  remindToday         Boolean @default(true)  // WhatsApp same-day "see you today?" check-in
  // ADMIN:
  emailAdminBooking   Boolean @default(true)  // booking confirmation email copy to the admin
  emailAdminWaCopy    Boolean @default(true)  // email a copy of every inbound WhatsApp message
  notifyAdminWhatsapp Boolean @default(true)  // WhatsApp new-booking alert to the admin number
  // Per-studio Google Calendar sync. Each studio admin connects THEIR OWN
  // Google account (OAuth) — entirely separate per studio. Presence of a
  // refresh token = connected. Classes one-way sync into googleCalendarId.
  googleRefreshToken  String?
  googleCalendarId    String?   // target calendar id, default "primary"
  googleEmail         String?   // connected Google account (for display)
  googleConnectedAt   DateTime?
  // Per-studio WhatsApp Cloud API credentials. Populated by /super-admin
  // either via Embedded Signup OAuth (future) or manual entry from Meta
  // Business Suite. If null we fall back to the global env vars so the
  // existing Canggu deployment keeps working unchanged.
  whatsappPhoneNumberId      String?
  whatsappAccessToken        String?
  whatsappBusinessAccountId  String?
  whatsappDisplayPhone       String?
  whatsappConnectedAt        DateTime?
  // Activation request submitted by the studio admin via /admin/settings.
  // The admin fills in the two values they got from Meta (Phone Number ID
  // + display phone); the request lands in /sadmin where the super-admin
  // generates a System User Token and approves — which copies the values
  // into the real whatsapp* fields above and flips whatsappEnabled to true.
  // status: "pending" | "approved" | "rejected" | null
  whatsappRequestPhoneNumberId  String?
  whatsappRequestDisplayPhone   String?
  whatsappRequestStatus         String?
  whatsappRequestedAt           DateTime?
  whatsappRequestReviewedAt     DateTime?
  whatsappRequestNote           String?
  // Super-admin gates whether this studio's admin can self-onboard
  // WhatsApp via the form in /admin/settings. Off by default — when the
  // super-admin flips it on, the form goes live and the admin can register
  // a number through the Cloud API end-to-end (SMS verification + 2FA).
  whatsappOnboardingEnabled  Boolean   @default(false)
  // 6-digit two-factor PIN used by Meta's /register endpoint. Generated
  // server-side on first activation, persisted so future re-registers
  // (e.g. token rotations) can reuse the same PIN without admin input.
  whatsappTwoFactorPin       String?
  // ISO 639-1 code (e.g. "ru", "en", "id"). When set, inbound WhatsApp
  // messages get auto-translated to this language for display in the
  // inbox; outbound replies typed in this language get auto-translated
  // to the client's detected language before delivery. Null = off.
  inboxLanguage              String?
  // Running total of transactional emails sent for this studio (booking
  // confirmations, trainer notifications, password resets). Shown in /sadmin
  // as a rough usage indicator.
  emailsSentCount            Int      @default(0)
  createdAt     DateTime @default(now())

  users        User[]
  trainers     Trainer[]
  timeSlots    TimeSlot[]
  blockedDays  BlockedDay[]
  studioBlocks StudioBlock[]
  payments     TrainerPayment[]
  expenses     Expense[]
  services     AdditionalService[]
  memberships  Membership[]
  whatsappConversations WhatsAppConversation[]
}

// A time-range the studio room is occupied by something OTHER than a class -
// currently sublease bookings made through the separate "studio-sublet"
// service, which talks to us only via /api/external/*. A block reserves the
// physical room: no class slot can be created over it, and the sublet service
// reads these (plus class slots) to know what's free. NEVER shown on the
// public client booking page.
model StudioBlock {
  id          String   @id @default(cuid())
  studioId    String
  studio      Studio   @relation(fields: [studioId], references: [id])
  date        String   // yyyy-MM-dd (Bali date)
  startTime   String   // HH:mm
  endTime     String   // HH:mm
  label       String?  // subtenant name / note shown in admin
  source      String   @default("SUBLET") // SUBLET (from the sublet service) | MANUAL
  externalRef String?  // the booking id in the sublet service, for idempotent delete
  createdAt   DateTime @default(now())

  @@index([studioId, date])
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  role                String               @default("TRAINER")
  // Display name. Trainers carry their name on the Trainer row; STAFF users
  // have no Trainer record, so their name lives here (nullable: legacy staff
  // created via the CLI script have none until an admin fills it in).
  name                String?
  studioId            String
  studio              Studio               @relation(fields: [studioId], references: [id])
  // The temporary password the super-admin can read in /sadmin: the auto-
  // generated 4-digit code at studio creation, or "0400" after a reset. Set to
  // null the moment the user changes their own password — that's the signal
  // that the super-admin no longer knows it (shown as "•••• changed").
  initialPassword     String?
  trainer             Trainer?
  passwordResetTokens PasswordResetToken[]
  pushTokens          NativePushToken[]
  webPushSubscriptions WebPushSubscription[]
  loginSessions       LoginSession[]
  // How the user wants to be notified for new chat messages.
  // SOUND_VIBRATION (default) | VIBRATION_ONLY | SOUND_ONLY
  chatNotifMode       String               @default("SOUND_VIBRATION")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

// A browser's Web Push subscription (PWA notifications). Lets the web admin /
// trainer cabinet ring like WhatsApp on a phone without a native app - works on
// Android Chrome and iOS 16.4+ when the site is added to the home screen.
model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Web sign-ins. Recorded when a user logs in via the browser (NextAuth uses
// stateless JWTs, so this table is purely for the admin "who's signed in"
// view — it isn't consulted on every request). Deduped per (user, device) so
// re-logging-in from the same browser refreshes lastSeenAt instead of piling
// up rows. Mobile devices are tracked separately via NativePushToken.
model LoginSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device     String   // friendly label, e.g. "Chrome · macOS"
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@unique([userId, device])
  @@index([userId])
}

// Expo push tokens registered by the mobile app for a logged-in user.
// One row per device — a user with iPhone + iPad would have two. The
// platform / deviceName fields help debugging delivery later; expoPushToken
// is what we send through the Expo Push API.
model NativePushToken {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expoPushToken String   @unique
  // Native FCM registration token (Android only). Lets us send chat pushes via
  // FCM HTTP v1 with a per-conversation collapse key, so multiple messages in
  // one chat collapse to a single notification - keeping the Android icon badge
  // equal to the unread-conversation count. iOS stays on Expo/APNs.
  fcmToken      String?
  platform      String
  deviceName    String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Trainer {
  id             String           @id @default(cuid())
  name           String
  whatsapp       String           @default("")
  userId         String           @unique
  // "Удалить тренера" = архив (audit 2026-06-12): hidden from lists and
  // login, but salary/schedule history stays intact. Restore via PATCH.
  archived  Boolean  @default(false)
  user           User             @relation(fields: [userId], references: [id])
  studioId       String
  studio         Studio           @relation(fields: [studioId], references: [id])
  timeSlots      TimeSlot[]
  assistedSlots  TimeSlot[]       @relation("SlotAssistant")
  commissionRate Int              @default(20)
  color          String           @default("#6366F1")
  // How this trainer is told about new bookings on their classes. Email is on
  // by default; WhatsApp only fires when the studio has WhatsApp connected.
  notifyEmail    Boolean          @default(true)
  notifyWhatsapp Boolean          @default(true)
  // In the round-robin pool for auto-assigned WhatsApp leads (Studio.autoAssignLeads).
  inLeadRotation Boolean          @default(false)
  payments       TrainerPayment[]
  assignedConversations WhatsAppConversation[] @relation("ConversationAssignedTrainer")
  conversationAccess    WhatsAppConversationAccess[] @relation("TrainerConversationAccess")
  sentMessages          WhatsAppMessage[]      @relation("MessageFromTrainer")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model BlockedDay {
  id        String   @id @default(cuid())
  date      String
  reason    String?
  studioId  String
  studio    Studio   @relation(fields: [studioId], references: [id])
  createdAt DateTime @default(now())

  @@unique([studioId, date])
}

model TrainerPayment {
  id        String   @id @default(cuid())
  trainerId String
  trainer   Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  studioId  String
  studio    Studio   @relation(fields: [studioId], references: [id])
  amount    Float
  month     String
  note      String?
  // "payout" = money paid to the trainer (reduces what's owed).
  // "accrual" = a manual amount the studio owes the trainer (e.g. a no-show
  // comp) — adds to ACCRUED / balance. Always a positive amount either way.
  kind      String   @default("payout")
  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  category    String
  description String?
  date        String
  studioId    String
  studio      Studio   @relation(fields: [studioId], references: [id])
  createdAt   DateTime @default(now())
}

model TimeSlot {
  id          String    @id @default(cuid())
  date        String
  startTime   String
  endTime     String
  trainerId   String?
  trainer     Trainer?  @relation(fields: [trainerId], references: [id])
  assistantId String?
  assistant   Trainer?  @relation("SlotAssistant", fields: [assistantId], references: [id])
  classType     String  @default("GROUP") // GROUP | KIDS | PRIVATE
  publicVisible Boolean @default(true)
  maxCapacity Int       @default(6)
  price       Float     @default(0)
  studioId    String
  studio      Studio    @relation(fields: [studioId], references: [id])
  bookings    Booking[]
  // Slots created together as a weekly recurrence share the same seriesId.
  // Null = standalone, one-off slot. Used by the schedule modal to offer
  // "Repeat weekly" and to "stop series" on a specific future occurrence.
  seriesId    String?
  // Google Calendar event id (when the studio has Google sync connected), so
  // we can update/delete the matching event.
  googleEventId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([seriesId])
  // Calendar fetches are always "this studio, this date range" — the single
  // hottest query in the app. Without this it's a full table scan per load.
  @@index([studioId, date])
  // Trainer schedule view filters by trainer.
  @@index([trainerId])
}

model Booking {
  id             String           @id @default(cuid())
  slotId         String
  slot           TimeSlot         @relation(fields: [slotId], references: [id])
  clientName     String
  clientEmail    String
  clientPhone    String
  clientTelegram String?
  status         String           @default("CONFIRMED")
  paymentType    String           @default("PENDING")
  paymentStatus  String           @default("UNPAID")
  // Indonesian local resident: the trainer ticked "Local" at payment, so this
  // class is charged at the studio's localPrice (e.g. 200k) instead of slot.price.
  // Kept in sync with priceTier === "LOCAL" for backward compatibility.
  localResident  Boolean          @default(false)
  // Price tier the coach marked for trainer-commission purposes:
  //   "FULL"   → slot.price (e.g. 300k)
  //   "MEMBER" → studio.membershipClassPrice (e.g. 250k) — subscription/pass
  //   "LOCAL"  → studio.localPrice (e.g. 200k) — Indonesian local
  // null = legacy booking; fall back to the localResident flag.
  priceTier      String?
  ticketCode     String           @default("")
  checkedIn      Boolean          @default(false)
  notes          String?
  services       BookingService[]
  // When a trainer marks this class as paid out of the client's membership
  // (paymentType = "MEMBERSHIP"), this points at the Membership batch a class
  // was deducted from. Lets us mark "из абонемента" on the ticket and restore
  // the class if the booking is later cancelled.
  membershipId   String?
  membership     Membership?      @relation(fields: [membershipId], references: [id])
  // Diagnostic fields for the trainer's WhatsApp notification — populated by
  // the booking POST handler so we can audit why a trainer didn't get pinged
  // even though the message was "accepted" by Meta. Values:
  //   sent       — Meta accepted the message (template / free-form text)
  //   failed     — Meta rejected it; reason in waNotifyTrainerError
  //   skipped    — Trainer has no whatsapp number set
  //   not_sent   — Default; row hasn't been processed yet
  waNotifyTrainerStatus    String?  @default("not_sent")
  waNotifyTrainerError     String?
  waNotifyTrainerMessageId String?
  // When the day-before class reminder was sent to the client (null = not yet).
  // Guards the daily reminder cron against double-sending.
  reminderSentAt DateTime?
  // When the same-day "are you still coming?" check-in (class_today_confirm)
  // was sent — ~2.5h before the class. Null = not yet. Guards the frequent
  // today-reminder cron against double-sending.
  todayReminderSentAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Counting confirmed attendees on a slot (capacity checks, client lists) is
  // run constantly — composite covers the `where slotId + status` pattern.
  @@index([slotId, status])
  // Client lookups by phone (membership balance, OTP autofill, cancel bot).
  @@index([clientPhone])
  // Restoring a class when a membership-paid booking is cancelled.
  @@index([membershipId])
}

model AdditionalService {
  id       String           @id @default(cuid())
  name     String
  price    Float
  active   Boolean          @default(true)
  studioId String
  studio   Studio           @relation(fields: [studioId], references: [id])
  bookings BookingService[]
}

model BookingService {
  id        String            @id @default(cuid())
  bookingId String
  booking   Booking           @relation(fields: [bookingId], references: [id])
  serviceId String
  service   AdditionalService @relation(fields: [serviceId], references: [id])
  // How this extra service was paid, recorded by the trainer independently of
  // the class payment (a class can go on a membership while a mat is paid cash).
  // CASH | EDC | QR | TRANSFER. Null = not yet specified / paid with the class.
  paymentType String?

  @@unique([bookingId, serviceId])
}

// One-time WhatsApp confirmation code a client must enter before a public
// booking is created. Stops drive-by spam booking — you can't confirm without
// a real WhatsApp number that received the code. One active row per (studio,
// phone), replaced on each send; expires after a few minutes, attempts capped.
model BookingOtp {
  id        String   @id @default(cuid())
  studioId  String
  phone     String // digits only (normalized)
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  // WhatsApp delivery tracking: the sent message's wamid + its latest delivery
  // status (sent | delivered | read | failed). The webhook updates this; the
  // booking widget polls it so a client who typed a number that isn't on
  // WhatsApp gets told instead of waiting forever for a code.
  waMessageId String?
  status      String  @default("sent")
  statusError String?

  @@index([studioId, phone])
}

// ---------------------------------------------------------------------------
// Memberships (абонементы)
//
// A membership is a prepaid batch of classes a client buys at the studio. Each
// purchase is its own row (so we keep who sold it + how it was paid), keyed by
// the client's phone and scoped to one studio (a Canggu pass is not valid in
// Ubud). The client's available balance for a phone is SUM(remainingClasses)
// across their rows for that studio.
//
// Deduction is trainer-only: when a trainer marks a class as paid out of the
// membership, we decrement the oldest row with remainingClasses > 0 and link
// the booking via Booking.membershipId. Clients never spend a class themselves
// — the booking flow only shows them an informational balance.
//
// Always sold as 5 classes; balance never expires.
// ---------------------------------------------------------------------------
model Membership {
  id               String   @id @default(cuid())
  studioId         String
  studio           Studio   @relation(fields: [studioId], references: [id])
  clientPhone      String   // same format as Booking.clientPhone
  clientName       String?
  totalClasses     Int      @default(5)
  remainingClasses Int      @default(5)
  // Price per class at the time of sale (studio.membershipClassPrice). Recorded
  // so reports stay accurate if the studio later changes the membership price.
  classPrice       Float?
  // How the membership purchase itself was paid (reuses the booking payment
  // vocabulary): CASH | EDC | QR | TRANSFER.
  paymentType      String   @default("CASH")
  // Who sold it — a trainer or an admin. userId + a display label for audit.
  soldByUserId     String?
  soldByName       String?
  note             String?
  bookings         Booking[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([studioId, clientPhone])
}

// ---------------------------------------------------------------------------
// WhatsApp inbox
//
// One Conversation per (studio, clientPhone). The "assignedTrainer" determines
// which trainer can see the chat in /trainer/inbox; null means admin-only
// (e.g. when a stranger writes to the business number before any booking).
//
// Assignment is updated by /api/bookings when a client books a slot: the new
// booking's trainer takes over the conversation.
//
// 24-hour rule (Meta): we can send free-form messages only when
// lastInboundAt is within the past 24h. Outside that window only approved
// templates work. We store lastInboundAt to render that UI affordance.
// ---------------------------------------------------------------------------
model WhatsAppConversation {
  id                String   @id @default(cuid())
  studioId          String
  studio            Studio   @relation(fields: [studioId], references: [id])
  clientPhone       String   // normalized to digits only, no leading +
  clientName        String?  // best-known name (latest booking or WhatsApp profile)
  // ISO 639-1 code detected from this client's inbound messages (e.g. "en",
  // "es", "ru"). Used as the target language when admin replies and the
  // studio has inboxLanguage set. Updated as fresher inbounds come in.
  clientLanguage    String?
  // assignedTrainerId — kept as the "primary / most-recent trainer" for sort
  // & display (chip in admin list). Actual access control is via the
  // WhatsAppConversationAccess join table below, which lets multiple
  // trainers see the same chat when a client booked with each of them.
  assignedTrainerId String?
  assignedTrainer   Trainer? @relation("ConversationAssignedTrainer", fields: [assignedTrainerId], references: [id])
  access            WhatsAppConversationAccess[]
  lastMessageAt     DateTime @default(now())
  lastInboundAt     DateTime?
  // Cancel-bot state: when a client texts a ticket code we ask "1=yes/0=no" and
  // park the booking id here until they answer (or it goes stale).
  pendingCancelBookingId String?
  pendingCancelAt        DateTime?
  // Set when the same-day class reminder (class_today_confirm) is sent: holds
  // the class trainer's WhatsApp number so the client's FIRST reply is
  // forwarded to that trainer. Cleared after the first reply is forwarded, so
  // only one reply per reminder reaches the trainer.
  pendingReminderTrainerPhone String?
  // Unread counters tracked separately per role so admin & trainer don't
  // clobber each other when one of them reads.
  unreadAdmin       Int      @default(0)
  unreadTrainer     Int      @default(0)
  // Set when a client books and cleared when admin/trainer opens the conversation.
  // Shown as a preview line in the inbox list so staff see "New booking · Class · Date"
  // without any WA message needed.
  bookingPreview    String?
  messages          WhatsAppMessage[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studioId, clientPhone])
  @@index([studioId, lastMessageAt])
  @@index([assignedTrainerId])
}

// Join table for "this trainer can see this conversation". One row per
// (conversation, trainer). Populated by the booking flow when a client books
// a slot — the slot's trainer gets a row here (idempotent), so multiple
// trainers can share access to a chat when the same client books with each.
model WhatsAppConversationAccess {
  id             String   @id @default(cuid())
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  trainerId      String
  trainer        Trainer  @relation("TrainerConversationAccess", fields: [trainerId], references: [id])
  grantedAt      DateTime @default(now())

  @@unique([conversationId, trainerId])
  @@index([trainerId])
}

model WhatsAppMessage {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction       String   // "INBOUND" | "OUTBOUND"
  type            String   // "text" | "image" | "audio" | "video" | "document" | "sticker" | "template" | "system"
  body            String?  // text body — sender's ORIGINAL words (inbound)
                           // OR admin's typed text (outbound, before translation)
  // Auto-translation: when studio.inboxLanguage is set we render bubbles using
  // translatedBody (falling back to body when no translation was needed/done).
  // For inbound: client wrote in `body` (their language), translatedBody is
  // the admin-facing translation.
  // For outbound: admin typed in `body` (studio's inboxLanguage),
  // translatedBody is what we actually sent to the client.
  translatedBody  String?
  // ISO 639-1 of `body` (detected once at persist time).
  detectedLang    String?
  // Which engine produced translatedBody: "gem" Gemini, "gro" Groq,
  // "cla" Claude, "dpl" DeepL, "goo" Google. Shown as a tiny label in the
  // inbox so we can see (and debug) translation quality at a glance.
  translatedVia   String?
  mediaUrl        String?  // we don't download media yet; store Meta media_id here for later fetching
  mediaMime       String?
  templateName    String?  // for outbound type=template
  waMessageId     String?  @unique // Meta's wamid.* for status correlation
  status          String   @default("queued") // queued | sent | delivered | read | failed
  errorDetail     String?
  // Emoji reaction the studio team put on this message (WhatsApp-style
  // long-press reaction). Null = none. Also mirrored to the client via the
  // Cloud API when the 24h window is open.
  reaction        String?
  fromTrainerId   String?  // OUTBOUND only: which trainer sent it (null = admin or system/booking-confirmation)
  fromTrainer     Trainer? @relation("MessageFromTrainer", fields: [fromTrainerId], references: [id])
  // Marker for messages imported from a previous WhatsApp export (one-time migration).
  importedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([waMessageId])
}

// Verbose pipeline logging (incident 2026-06-11: reminders silently dead).
// Written by lib/elog.ts at every notification-pipeline step while
// NOTIF_DEBUG is not "0". Meant to run hot for a week or two after an
// incident, then be switched off via env — rows are cheap, truth is not.
model EventLog {
  id        String   @id @default(cuid())
  scope     String // e.g. "cron:today-reminders", "wa:send", "webhook:status"
  level     String   @default("info") // info | warn | error
  message   String
  data      String? // JSON payload, truncated
  createdAt DateTime @default(now())

  @@index([scope, createdAt])
  @@index([createdAt])
}

// Distributed claim for traffic-driven cron fallbacks (see lib/reminder-tick).
model CronTick {
  id        String   @id // job name, e.g. "today-reminders"
  lastRunAt DateTime
}

// Fixed-window rate limiting for PUBLIC endpoints (audit 2026-06-12: otp/send,
// bookings POST and native login had no abuse protection at all). Key =
// "<scope>:<ip-or-phone>:<windowStart>"; rows expire and are lazily purged.
model RateLimit {
  id        String   @id @map("key")
  count     Int      @default(1)
  expiresAt DateTime
}

// Trainer-to-trainer class handover (trainer request 2026-06-12: Gr covered
// Seni's class with no way to log it). Strictly GIVE-initiated: the slot's
// owner offers a specific colleague; the colleague accepts/declines from the
// bell. On accept the whole class moves — slot.trainerId, the clients'
// chats and the reminder forward — so payments and salary land correctly.
model SlotHandover {
  id            String    @id @default(cuid())
  slotId        String
  studioId      String
  fromTrainerId String
  toTrainerId   String
  note          String?
  status        String    @default("PENDING") // PENDING | ACCEPTED | DECLINED | CANCELLED | EXPIRED
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  @@index([toTrainerId, status])
  @@index([fromTrainerId, status])
  @@index([slotId, status])
}
